{
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/",
      "framework": "angular",
      "buildCommand": "npm run build -- --configuration production",
      "outputDirectory": "dist/rh-management",
      "rewrites": [
        { "source": "/(.*)", "destination": "/index.html" }
      ]
    }
  }
}
